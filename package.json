{
  "name": "opencode-vscode-client",
  "displayName": "OCVS — OpenCode client for VS Code",
  "description": "Lightweight frontend for the OpenCode AI agent backend with native VS Code UI",
  "version": "0.1.0",
  "publisher": "alexup71rus",
  "icon": "media/icon.png",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexup71rus/opencode-for-vscode-light"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Chat"
  ],
  "main": "./dist/extension/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "opencode.openPanel",
        "title": "OCVS: Open Chat Panel"
      },
      {
        "command": "opencode.newSession",
        "title": "OCVS: New Session"
      }
    ],
    "configuration": {
      "title": "OCVS",
      "properties": {
        "opencode.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the opencode binary. Leave empty for auto-detect via PATH."
        },
        "opencode.externalServerUrl": {
          "type": "string",
          "default": "",
          "description": "Connect to an external opencode server URL instead of spawning one. Example: http://127.0.0.1:4096"
        },
        "opencode.serverPassword": {
          "type": "string",
          "default": "",
          "description": "Password for external server. For spawned servers, a random password is auto-generated."
        },
        "opencode.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default model in provider/model format. Example: anthropic/claude-sonnet-4-20250514"
        },
        "opencode.serverHostname": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Hostname for the spawned opencode server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "node esbuild.mjs",
    "compile:webview": "vite build",
    "watch:extension": "node esbuild.mjs --watch",
    "watch:webview": "vite build --watch",
    "lint": "tsc --noEmit -p tsconfig.extension.json && tsc --noEmit -p tsconfig.webview.json",
    "lint:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "node --import tsx --test test/*.test.ts",
    "package:vsix": "vsce package --no-dependencies",
    "dev:install": "bash scripts/dev-install.sh",
    "bump": "bash scripts/bump-version.sh"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.13",
    "@vscode/codicons": "^0.0.45",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.23.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "zustand": "^4.5.0"
  }
}
